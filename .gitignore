# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.so

# --- Virtual environments (mstm-env is recreated per README; never commit venvs) ---
.venv/
venv/
env/
mstm-env/

# --- Tooling / test caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# --- Editors / OS cruft ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Secrets / local env ---
.env
*.local

# --- Generated, reproducible artifacts ---------------------------------------
# Figures are regenerated by scripts/*.py; the T-matrix cache is rebuilt by
# scripts/build_tmatrix_basis.py (~5 min). Ignore them by default.
# If the README embeds specific figures, either force-add them
# (git add -f outputs/figX.png) or move them into a tracked docs/ folder.
outputs/*.png
outputs/*.npz

# --- Raw / unpublished experimental data -------------------------------------
# Do NOT publish lab data to a public repo unless you intend to share it.
data/experimental/
*.xlsx
*.xls
experimental/

# --- MUST STAY TRACKED (do not add ignore rules that catch these) ------------
#   src/aunp_speciation/data/gold_bb.npz  -> required for the 'bb' dielectric
#   data/example_series.csv               -> demo input for scripts/fit_real.py
# These are safe above: the .npz rule is path-scoped to outputs/, and the data
# rule only matches spreadsheets, not .npz/.csv.
# --- Claude Code local settings ---
.claude/settings.local.json
